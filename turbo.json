{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "persistent": true,
      "cache": false
    },
    "_typecheck": {
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "tsconfig.json"]
    },
    "_build:preload": {
      "inputs": ["src/preload.ts"],
      "outputs": ["dist/preload.js"]
    },
    "_build": {
      "dependsOn": ["_typecheck"],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "tsconfig.json"],
      "outputs": ["dist/**"]
    },
    "_check": {
      "dependsOn": ["_typecheck", "_build"]
    },
    "test:e2e": {
      "dependsOn": ["_build"],
      "cache": false
    }
  }
}
